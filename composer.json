{
  "name": "foliovision/fv-wordpress-flowplayer",
  "version": "8.1.4",
	"description": "FV Player - Wordpress's most reliable, easy to use and feature-rich video player.",
	"type": "wordpress-plugin",
  "config": {
    "platform": {
        "php": "8.1"
    }
  },
  "require-dev": {
    "mockery/mockery": "dev-main",
    "yoast/phpunit-polyfills": "dev-main"
  },
  "require": {
    "aws/aws-sdk-php": "^3.235"
  },
  "scripts": {
    "pre-autoload-dump": "Aws\\Script\\Composer\\Composer::removeUnusedServices"
  },
  "extra": {
    "aws/aws-sdk-php": [
      "S3",
      "CloudFront"
    ]
  }
}
